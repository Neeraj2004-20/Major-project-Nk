# Deployment environment variables template
# Copy this file to .env and update with your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your-secret-api-key-here
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Model Configuration
MODEL_PATH=outputs/model_AAPL_latest.pt
USE_GPU=false
MAX_BATCH_SIZE=32

# Data Configuration
DATA_CACHE_TTL=3600
ENABLE_LIVE_DATA=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=

# Database (Optional)
DATABASE_URL=postgresql://user:password@localhost:5432/market_predictor
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Monitoring
ENABLE_METRICS=true
PROMETHEUS_PORT=9090
